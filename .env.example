# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SOLO en servidor, nunca en frontend (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://crewficina.com

# Owner bypass — acceso ilimitado sin restricciones de plan (solo para el dueño del producto)
VITE_OWNER_EMAIL=tu@email.com

# ── Stripe — servidor ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe — frontend + servidor (price IDs no son secretos) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRICE_SOLO_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_SOLO_PRO_YEARLY=price_...
VITE_STRIPE_PRICE_STUDIO_MONTHLY=price_...
VITE_STRIPE_STUDIO_PRICE_ID=price_...
VITE_STRIPE_PRICE_STUDIO_YEARLY=price_...
